<UserControl x:Class="ChinaDemographicModel.UI.Controls.YearSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="60"
             MinWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Canvas Grid.Row="0" x:Name="TrackCanvas"
                Background="Transparent" Cursor="Hand"
                ClipToBounds="False"
                SizeChanged="TrackCanvas_SizeChanged"
                MouseLeftButtonDown="TrackCanvas_MouseLeftButtonDown"
                MouseMove="TrackCanvas_MouseMove"
                MouseLeftButtonUp="TrackCanvas_MouseLeftButtonUp"
                MouseLeave="TrackCanvas_MouseLeave"/>

        <Canvas Grid.Row="1" x:Name="LabelCanvas" Height="16" Margin="0,6,0,0"
                Background="Transparent"/>
    </Grid>
</UserControl>
