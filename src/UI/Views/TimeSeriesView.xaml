<UserControl x:Class="ChinaDemographicModel.UI.Views.TimeSeriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="时间序列" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
            <TextBlock Style="{StaticResource SubtitleText}" VerticalAlignment="Center" Margin="12,0,0,0"
                       Text="实线：当前场景  ·  虚线：历史观测"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource BgSurfaceBrush}" CornerRadius="10"
                Margin="0,0,0,8" Padding="6">
            <ScottPlot:WpfPlot x:Name="BirthsPlot"/>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource BgSurfaceBrush}" CornerRadius="10"
                Margin="0,0,0,8" Padding="6">
            <ScottPlot:WpfPlot x:Name="DeathsPlot"/>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource BgSurfaceBrush}" CornerRadius="10"
                Margin="0,0,0,8" Padding="6">
            <ScottPlot:WpfPlot x:Name="MarriagePlot"/>
        </Border>

        <TextBlock Grid.Row="4" Style="{StaticResource SubtitleText}"
                   Text="上：年出生（万人）　·　中：年死亡（万人）　·　下：粗结婚率（‰）"/>
    </Grid>
</UserControl>
