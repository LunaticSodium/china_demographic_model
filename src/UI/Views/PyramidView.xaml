<UserControl x:Class="ChinaDemographicModel.UI.Views.PyramidView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="人口金字塔 · " Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentYear}" Foreground="{StaticResource AccentPrimaryBrush}"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="{StaticResource AccentPrimaryBrush}" CornerRadius="3" Width="10" Height="10" Margin="0,0,6,0"/>
                <TextBlock Text="男" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Border Background="{StaticResource AccentTertiaryBrush}" CornerRadius="3" Width="10" Height="10" Margin="0,0,6,0"/>
                <TextBlock Text="女" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Border Background="{StaticResource BgSurfaceBrush}"
                    CornerRadius="10"
                    ClipToBounds="True">
                <Canvas x:Name="PyramidCanvas"
                        SizeChanged="PyramidCanvas_SizeChanged"
                        MouseMove="PyramidCanvas_MouseMove"
                        MouseLeave="PyramidCanvas_MouseLeave"
                        Background="Transparent"/>
            </Border>

            <!-- 引用面板：覆盖在金字塔右下角；不响应 hit-test，使 hover tooltip 仍生效 -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,16,16" MaxWidth="380"
                    Background="{StaticResource BgCardBrush}" Opacity="0.94"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="10,8"
                    IsHitTestVisible="False">
                <TextBlock Text="{Binding CitationText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Consolas, Cascadia Mono, monospace"
                           FontSize="10"
                           TextWrapping="Wrap"
                           LineHeight="14"/>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Style="{StaticResource SubtitleText}" Margin="0,8,0,0"
                   Text="横轴：人数（万人）　·　纵轴：年龄。负向为男，正向为女。 baseline 实色 / counterfactual 描边线（如已克隆场景）"/>
    </Grid>
</UserControl>
