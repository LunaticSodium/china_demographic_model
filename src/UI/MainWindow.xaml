<Window x:Class="ChinaDemographicModel.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ChinaDemographicModel.UI.Views"
        xmlns:vm="clr-namespace:ChinaDemographicModel.UI.ViewModels"
        xmlns:controls="clr-namespace:ChinaDemographicModel.UI.Controls"
        Title="中国人口结构 · 紧模型 / 反事实工具"
        Width="1480" Height="900"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部条 -->
        <Border Grid.Row="0"
                Style="{StaticResource Card}"
                Margin="0,0,0,16"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="中国人口结构 · 紧模型 / 反事实工具" Style="{StaticResource TitleText}"/>
                    <TextBlock Text="Cohort-Component projection · 历史一致性约束 · 反事实推演"
                               Style="{StaticResource SubtitleText}" Margin="0,2,0,0"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="20,0,16,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Border Width="8" Height="8" CornerRadius="2" Margin="0,0,4,0" Background="{StaticResource BgElevBrush}"/>
                        <TextBlock Text="一般" Style="{StaticResource SubtitleText}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <Border Width="8" Height="8" CornerRadius="2" Margin="0,0,4,0" Background="{StaticResource CensusBrush}"/>
                        <TextBlock Text="普查" Style="{StaticResource SubtitleText}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <Border Width="8" Height="8" CornerRadius="2" Margin="0,0,4,0" Background="{StaticResource ForecastBrush}"/>
                        <TextBlock Text="预测" Style="{StaticResource SubtitleText}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <Border Width="8" Height="8" CornerRadius="2" Margin="0,0,4,0" Background="{StaticResource WarnBrush}"/>
                        <TextBlock Text="反事实" Style="{StaticResource SubtitleText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:YearSlider Grid.Column="1"
                                         Minimum="{Binding YearMin}"
                                         Maximum="{Binding YearMax}"
                                         Value="{Binding CurrentYear, Mode=TwoWay}"
                                         CensusYears="{Binding CensusYears}"
                                         LastObservedYear="{Binding LastObservedYear}"
                                         IsCounterfactual="{Binding IsCounterfactualScenario}"
                                         MinWidth="500"
                                         VerticalAlignment="Center"
                                         Margin="0,0,16,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding CurrentYear}" FontSize="22" FontWeight="Light"
                               Foreground="{StaticResource AccentPrimaryBrush}" MinWidth="58"
                               VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↺ 重置基线" Style="{StaticResource GhostButton}"
                            Command="{Binding ResetScenarioCommand}" Margin="0,0,8,0"/>
                    <Button Content="▶ 重跑投影" Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunProjectionCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主区 三栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="场景" Style="{StaticResource SectionHeader}"/>
                        <ListBox ItemsSource="{Binding Scenarios}"
                                 SelectedItem="{Binding ActiveScenario, Mode=TwoWay}"
                                 MaxHeight="180"
                                 BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="#FF38BDF8"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="＋克隆为反事实" Command="{Binding CloneScenarioCommand}"
                                    Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="约束模式" Style="{StaticResource SectionHeader}"/>
                        <CheckBox Content="锁定历史观测（紧模型）"
                                  IsChecked="{Binding LockToHistory, Mode=TwoWay}"
                                  Margin="0,0,0,6"/>
                        <TextBlock Style="{StaticResource SubtitleText}"
                                   Text="开启时：所有 1978–2024 已观测年的出生数 / 性别比强制等于历史。仅 ASFR / 死亡率 / 预测年可被反事实修改。"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="数据健康" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="{Binding HealthReport}" Style="{StaticResource SubtitleText}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- CENTER -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="20">
                <TabControl>
                    <TabItem Header="人口金字塔">
                        <views:PyramidView DataContext="{Binding}" />
                    </TabItem>
                    <TabItem Header="时间序列">
                        <views:TimeSeriesView DataContext="{Binding}" />
                    </TabItem>
                    <TabItem Header="输入编辑">
                        <views:InputsEditorView DataContext="{Binding}" />
                    </TabItem>
                </TabControl>
            </Border>

            <!-- RIGHT -->
            <StackPanel Grid.Column="2" Margin="16,0,0,0">
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="当前年指标" Style="{StaticResource SectionHeader}"/>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,6,8,10">
                            <TextBlock Text="总人口" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding TotalPopulationDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,6,0,10">
                            <TextBlock Text="当年出生" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding BirthsDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="出生性别比" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding SrbDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,10">
                            <TextBlock Text="TFR" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding TfrDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="平均初婚（男）" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding MafmMaleDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,10">
                            <TextBlock Text="平均初婚（女）" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding MafmFemaleDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,10">
                            <TextBlock Text="粗结婚率（‰）" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding MarriageRateDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,10">
                            <TextBlock Text="当年死亡（观测）" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding DeathsDisplay}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,0">
                            <TextBlock Text="e0 (观测，男/女)" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding E0Display}" Style="{StaticResource MetricValue}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="偏离基线" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="{Binding DeviationReport}" Style="{StaticResource SubtitleText}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="日志" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="{Binding StatusLog}" Style="{StaticResource SubtitleText}"
                                   MaxHeight="200" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
